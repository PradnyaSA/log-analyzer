# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ---------------------------------------------------------------------------
# Option B: Google AI Studio (no GCP required)
# Get a free key at https://aistudio.google.com → API Keys → Create
# ---------------------------------------------------------------------------
# GOOGLE_API_KEY=your_api_key_here

# ---------------------------------------------------------------------------
# Option C: Vertex AI (GCP credentials via `gcloud auth application-default login`)
# Leave GOOGLE_API_KEY unset and the agent will use Vertex AI automatically.
# ---------------------------------------------------------------------------
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ---------------------------------------------------------------------------
# Jira integration (optional — required for file_jira_ticket to create tickets)
# Without these, the tool returns "status": "skipped" but the flow still works.
# ---------------------------------------------------------------------------
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_PROJECT_KEY=ENG
# JIRA_ASSIGNEE_EMAIL=engineer@your-org.com

# ---------------------------------------------------------------------------
# Incident management (optional — required for update_incident_status)
# ---------------------------------------------------------------------------
# INCIDENT_API_URL=https://your-incident-api.example.com
# INCIDENT_API_TOKEN=your_incident_api_token
