# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ---------------------------------------------------------------------------
# Option B: Google AI Studio (no GCP required)
# Get a free key at https://aistudio.google.com → API Keys → Create
# ---------------------------------------------------------------------------
# GOOGLE_API_KEY=your_api_key_here

# ---------------------------------------------------------------------------
# Option C: Vertex AI (GCP credentials via `gcloud auth application-default login`)
# Leave GOOGLE_API_KEY unset and the agent will use Vertex AI automatically.
# ---------------------------------------------------------------------------
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ---------------------------------------------------------------------------
# Jira integration
# Option 1 — Atlassian Rovo MCP (recommended): set ATLASSIAN_MCP_URL to enable.
#   Reuses JIRA_USER_EMAIL + JIRA_API_TOKEN for auth.
# Option 2 — Direct REST API fallback: leave ATLASSIAN_MCP_URL unset.
# ---------------------------------------------------------------------------
# ATLASSIAN_MCP_URL=https://mcp.atlassian.com/v1/sse
# JIRA_USER_EMAIL=your-account@your-org.com   # email used to generate the API token
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_BASE_URL=https://your-org.atlassian.net  # only needed for direct REST fallback
# JIRA_PROJECT_KEY=ENG                          # only needed for direct REST fallback
# JIRA_ISSUE_TYPE=Task                          # only needed for direct REST fallback

# ---------------------------------------------------------------------------
# Incident management (optional — required for update_incident_status)
# ---------------------------------------------------------------------------
# INCIDENT_API_URL=https://your-incident-api.example.com
# INCIDENT_API_TOKEN=your_incident_api_token
